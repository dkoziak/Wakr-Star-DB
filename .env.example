# ==============================================================================
# Environment Configuration Example (.env.example) for Wakr Star DB API
# Copy this file as `.env` into the `src/` folder or project root and fill in the values
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Database Connection Settings
# ------------------------------------------------------------------------------
# PostgreSQL connection settings.
# Priority: If `STARDB_URL` is set, all individual variables (`STARDB_HOST`, etc.) are ignored.
# Otherwise, `stardb_url` is constructed dynamically from individual variables.

# Option A: Unified Connection URL (takes precedence)
# Make sure to use the `asyncpg` driver for asynchronous database operations.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
STARDB_URL=

# Option B: Individual database connection variables (fallback if STARDB_URL is empty)
STARDB_HOST=localhost
STARDB_PORT=5432
STARDB_DB=wakr
STARDB_USER=wakr
STARDB_PASSWORD=wakr


# ------------------------------------------------------------------------------
# 2. Debug Mode
# ------------------------------------------------------------------------------
# If set to `true`, authorization is completely bypassed (or accepts any input).
# Use `true` strictly for local development and running tests.
# For production environments, always set this to `false`.
DEBUG=true


# ------------------------------------------------------------------------------
# 3. Bearer JWT Authorization Settings (RS256)
# ------------------------------------------------------------------------------
# Token issuer URL (Identity Provider / Auth0 / Keycloak / etc.).
# Used to validate the `iss` claim in the JWT token.
TOKEN_ISSUER=https://your-idp.example.com/

# Token audience.
# Used to validate the `aud` claim in the JWT token.
TOKEN_AUDIENCE=https://api.wakr.co

# Public key in PEM format (for RS256 signature verification).
# Must contain "-----BEGIN PUBLIC KEY-----" and "-----END PUBLIC KEY-----" at start and end.
# If `DEBUG=true` is enabled, this field can be left blank.
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...\n-----END PUBLIC KEY-----"


# ------------------------------------------------------------------------------
# 4. Static API Key Settings (Machine-to-Machine Auth)
# ------------------------------------------------------------------------------
# Static API key for authenticating third-party services or scripts (e.g., Cloudflare Workers).
# Clients must send this key in the `X-API-Key` HTTP header.
# If this variable is empty, authorization via the `X-API-Key` header will be disabled.
ANALYTICS_API_KEY=your-super-secure-static-api-key-here


# ------------------------------------------------------------------------------
# 5. Domain Configuration for Caddy SSL / HTTP/HTTPS proxy
# ------------------------------------------------------------------------------
# Domain name for Caddy automatic HTTPS certificate provisioning (e.g. api.wakr.co)
DOMAIN_NAME=localhost
